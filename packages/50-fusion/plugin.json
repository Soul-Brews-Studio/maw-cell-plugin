{
  "name": "fusion",
  "version": "0.2.0",
  "weight": 50,
  "entry": "./index.ts",
  "sdk": "^1.0.0",
  "description": "Fuse two oracles — merge knowledge across vaults with provenance and conflict detection",
  "cli": {
    "command": "fusion",
    "help": "maw fusion <source-oracle> [--into <target>] [--dry-run] [--category <cat>] [--json]",
    "flags": {
      "--into": "string",
      "--dry-run": "boolean",
      "--json": "boolean",
      "--category": "string"
    }
  },
  "api": {
    "path": "/api/fusion",
    "methods": ["POST"]
  },
  "transport": { "peer": true }
}
